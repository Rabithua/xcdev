# Project settings
IOS_PROJECT="MetaLoft.xcodeproj"
IOS_SCHEME="MetaLoft"
IOS_CONFIGURATION="Debug"
IOS_ENABLE_DEBUG_DYLIB="NO"
IOS_BUNDLE_ID="com.example.yourapp"

# Profile settings
IOS_PROFILE_DEFAULT="sim"

IOS_PROFILE_SIM_MODE="sim"
IOS_PROFILE_SIM_TARGET="iPhone"

IOS_PROFILE_REAL_MODE="real"
IOS_PROFILE_REAL_TARGET="iPhone"

# Optional custom profile examples:
# IOS_PROFILE_AIR_MODE="sim"
# IOS_PROFILE_AIR_TARGET="iPhone Air"
